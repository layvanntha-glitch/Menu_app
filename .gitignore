# ---- Secrets (NEVER commit) ----
telegram/.token
telegram/.miniapp_url

# ---- Runtime data (customer orders, accounts) — auto-created on first run ----
/data/*
!/data/.htaccess

# ---- User uploads (regenerated per install) ----
/uploads/*
!/uploads/.htaccess

